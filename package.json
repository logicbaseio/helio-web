{
  "name": "helio-dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .js,.jsx",
    "test": "vitest run",
    "deadcode": "knip",
    "shelllint": "sh -c 'if command -v shellcheck >/dev/null 2>&1; then scripts=$(find . -type f -name \"*.sh\" | tr \"\\n\" \" \"); if [ -n \"$scripts\" ]; then shellcheck $scripts; else echo \"No shell scripts found\"; fi; else echo \"shellcheck not installed\"; fi'"
  },
  "dependencies": {
    "jspdf": "^4.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "knip": {
    "ignore": [
      "dist/**",
      "backups/**",
      "helio_dashboard.tsx",
      "vite.config.d.ts"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "knip": "^6.14.0",
    "playwright": "^1.60.0",
    "typescript": "^5.8.3",
    "vite": "^5.4.12",
    "vitest": "^4.1.6"
  }
}
